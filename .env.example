# ===========================================
# TEMPLATE DE VARIABLES DE ENTORNO - FRONTEND
# ===========================================
# Vite carga automaticamente:
# - .env.development para 'npm run dev'
# - .env.production para 'npm run build'
# - .env para ambos (valores por defecto)

# URL del API Backend
# - Desarrollo local: http://localhost:4015/api
# - Railway (produccion): https://tu-backend.up.railway.app/api
VITE_API_URL=http://localhost:4015/api

# Modo del entorno (development | production)
VITE_APP_ENV=development
